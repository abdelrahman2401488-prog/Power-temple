<% extraCss = '<link rel="stylesheet" href="/css/shop.css" />' %>
<% extraJs = '<script src="/js/shop.js" defer></script>' %>
<%- include('partials/head') %>
<body data-page="shop">
  <div class="app">
    <%- include('partials/header-public', { activePage: 'shop' }) %>

    <div class="promo-strip">🔥 FREE SHIPPING ON ORDERS OVER LE 500 &nbsp;•&nbsp; USE CODE PT20 FOR 20% OFF YOUR FIRST ORDER &nbsp;•&nbsp; 🔥 FREE SHIPPING ON ORDERS OVER LE 500 &nbsp;•&nbsp; USE CODE PT20 FOR 20% OFF</div>

    <section class="shop-hero">
      <div class="container">
        <span class="shop-hero-label">⚡ Power Temple Nutrition</span>
        <h1>FUEL YOUR<br><span>GAINS</span></h1>
        <p>Premium supplements engineered for peak performance. Pre-workout, protein, creatine, and more — gym-tested, elite-approved.</p>
        <div class="filter-bar">
          <button class="filter-btn active" data-filter="all">All Products</button>
          <button class="filter-btn" data-filter="pre-workout">Pre-Workout</button>
          <button class="filter-btn" data-filter="protein">Protein</button>
          <button class="filter-btn" data-filter="creatine">Creatine</button>
          <button class="filter-btn" data-filter="bars">Protein Bars</button>
          <button class="filter-btn" data-filter="vitamins">Vitamins</button>
          <button class="filter-btn" data-filter="recovery">Recovery</button>
        </div>
      </div>
    </section>

    <main class="container">
      <section class="products-section">
        <h2 class="shop-section-title">TOP <span>SELLERS</span></h2>
        <%
          var catLabels = { 'pre-workout': 'Pre-Workout', protein: 'Protein', creatine: 'Creatine', bars: 'Protein Bars', vitamins: 'Vitamins', recovery: 'Recovery' };
        %>
        <div class="products-grid" id="productsGrid">
          <% (products || []).forEach(function (p) { %>
            <article class="product-card" id="product-<%= p._id %>" data-category="<%= p.category %>" data-product-name="<%= p.name %>" data-product-price="<%= p.price %>" data-product-unit="<%= p.unit || '' %>">
              <% if (p.badge) { %><div class="product-badge"><%= p.badge %></div><% } %>
              <div class="product-img-wrap"><img src="<%= p.image %>" alt="<%= p.name %>" loading="lazy"/></div>
              <div class="product-info">
                <span class="product-category"><%= catLabels[p.category] || p.category %></span>
                <h3 class="product-name"><%= p.name %></h3>
                <p class="product-desc"><%= p.description %></p>
              </div>
              <div class="product-footer">
                <div class="product-price">LE <%= Number(p.price).toLocaleString() %> <span><%= p.unit || '' %></span></div>
                <button class="add-to-cart-btn" data-product-name="<%= p.name %>" data-product-price="<%= p.price %>"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11 11V5h2v6h6v2h-6v6h-2v-6H5v-2z"/></svg>ADD</button>
              </div>
            </article>
          <% }) %>
        </div>
      </section>

      <footer class="footer">
        <div class="footer-grid">
          <div class="footer-col footer-about">
            <div class="footer-brand-row"><a class="brand footer-brand" href="/"><span class="brand-mark">PT</span></a></div>
            <p class="footer-copy">Power Temple helps you build strength and confidence with expert trainers, performance-driven plans, and a community built for real results.</p>
          </div>
          <div class="footer-col">
            <h3 class="footer-head">Shop</h3>
            <ul class="footer-list">
              <li><a href="#">Pre-Workout</a></li><li><a href="#">Proteins</a></li><li><a href="#">Creatine</a></li><li><a href="#">Protein Bars</a></li><li><a href="#">Vitamins</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h3 class="footer-head">Quick Links</h3>
            <ul class="footer-list">
              <li><a href="/">Home</a></li><li><a href="/member/browse-classes">Classes</a></li><li><a href="/memberships">Memberships</a></li><li><a href="/services">Services</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h3 class="footer-head">Contact</h3>
            <div class="footer-contact">
              <p><strong>Phone:</strong> <a href="tel:0101234567">0101234567</a></p>
              <p><strong>Email:</strong> <a href="mailto:powertemple@gmail.com">powertemple@gmail.com</a></p>
            </div>
          </div>
        </div>
      </footer>

      <section class="shop-newsletter">
        <div class="newsletter-card">
          <div class="newsletter-copy">
            <span class="eyebrow">LATEST NEWS</span>
            <h2>Subscribe for exclusive offers and updates</h2>
            <p>Get the newest product launches, workout tips, and discount codes sent directly to your inbox.</p>
          </div>
          <div class="newsletter-form">
            <input id="shopNewsletterEmail" type="email" placeholder="Enter your email address" />
            <button id="shopNewsletterBtn" type="button">Subscribe</button>
          </div>
        </div>
      </section>
    </main>
  </div>

  <div id="cartToast" class="cart-toast"><span>✅</span><span id="cartToastMsg">Item added to cart!</span></div>
  <%- include('partials/cart-drawer') %>
  <%- include('partials/login-modal') %>
</body>
</html>
