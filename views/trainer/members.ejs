<%- include('../partials/head') %>
<body data-page="trainer">
  <div class="app">
    <%- include('../partials/header-trainer', { activePage: 'members' }) %>
    <main class="container">
      <%- include('../partials/hero-video') %>
      <section class="dashboard-layout">
        <div class="dashboard-banner fade-in">
          <div><h2>My Members</h2><p>Personal training requests and members booked into your classes.</p></div>
          <a class="btn btn-primary" href="/trainer/my-schedule">View Schedule</a>
        </div>

        <% if (locals.flash) { %>
          <div style="margin-bottom: 20px; padding: 12px 16px; background: rgba(0,212,255,0.1); border-left: 3px solid var(--primary-color); border-radius: 6px; color: var(--primary-color);">
            <%= flash %>
          </div>
        <% } %>

        <%
          var requests = locals.requests || [];
          var classes  = locals.classes  || [];
          var bookings = locals.bookings || [];
        %>
        <!-- Stats -->
        <div class="stat-grid" style="margin-bottom: 32px;">
          <div class="stat fade-in"><strong><%= requests.length %></strong><span>PT Requests</span></div>
          <div class="stat fade-in"><strong><%= requests.filter(function(r){ return r.status === 'pending'; }).length %></strong><span>Pending</span></div>
          <div class="stat fade-in"><strong><%= classes.length %></strong><span>My Classes</span></div>
          <div class="stat fade-in"><strong><%= bookings.length %></strong><span>Class Bookings</span></div>
        </div>

        <!-- Personal Training Requests -->
        <div class="panel-head" style="margin-bottom: 16px;">
          <div><h3>Personal Training Requests</h3><p>Accept or refuse session requests from members.</p></div>
        </div>

        <% if (requests.length > 0) { %>
          <% requests.forEach(function(r) { %>
            <%
              var pill = 'warning';
              if (r.status === 'confirmed') pill = 'success';
              else if (r.status === 'cancelled') pill = 'danger';
            %>
            <article class="row-card fade-in" style="margin-bottom: 12px;">
              <div class="row-main">
                <strong>👤 <%= r.memberName %></strong>
                <span class="row-meta">
                  <%= r.sessionType %> · <%= r.date %> at <%= r.time %>
                  <% if (r.notes) { %> · "<%= r.notes %>"<% } %>
                </span>
              </div>
              <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-top: 8px;">
                <span class="pill <%= pill %>"><%= r.status %></span>
                <% if (r.status === 'pending') { %>
                  <form action="/trainer/pt-request/confirm/<%= r._id %>" method="POST" style="margin: 0;">
                    <button class="btn btn-primary" type="submit" style="padding: 6px 14px; font-size: 0.85rem;">Accept</button>
                  </form>
                  <form action="/trainer/pt-request/cancel/<%= r._id %>" method="POST" style="margin: 0;">
                    <button class="btn btn-ghost" type="submit" style="padding: 6px 14px; font-size: 0.85rem; color: var(--danger-color);" onclick="return confirm('Refuse this request?')">Refuse</button>
                  </form>
                <% } %>
              </div>
            </article>
          <% }) %>
        <% } else { %>
          <div class="empty-state" style="margin-bottom: 32px;">No personal training requests yet.</div>
        <% } %>

        <!-- Class Bookings -->
        <div class="panel-head" style="margin: 32px 0 16px;">
          <div><h3>Members in My Classes</h3><p>Members currently booked into your group classes.</p></div>
        </div>

        <% if (bookings.length > 0) { %>
          <% bookings.forEach(function(b) { %>
            <article class="row-card fade-in" style="margin-bottom: 12px;">
              <div class="row-main">
                <strong>👤 <%= b.memberName || 'Member' %></strong>
                <span class="row-meta"><%= b.className %> · <%= b.time %></span>
              </div>
              <span class="pill success">confirmed</span>
            </article>
          <% }) %>
        <% } else { %>
          <div class="empty-state">No members booked into your classes yet.</div>
        <% } %>

      </section>
    </main>
  </div>
</body>
</html>
