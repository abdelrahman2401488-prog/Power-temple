<%- include('../partials/head') %>
<body data-page="trainer">
  <div class="app">
    <%- include('../partials/header-trainer', { activePage: 'members' }) %>
    <main class="container">
      <%- include('../partials/hero-video') %>
      <section class="dashboard-layout">
        <div class="dashboard-banner fade-in">
          <div><h2>My Assigned Members</h2><p>Members currently booked into your classes. Reach out, review progress, prepare sessions.</p></div>
          <a class="btn btn-primary" href="/trainer/my-schedule">View Schedule</a>
        </div>
        <div class="stat-grid" style="margin-bottom: 32px;">
          <div class="stat fade-in"><strong id="trMemCount">0</strong><span>Assigned Members</span></div>
          <div class="stat fade-in"><strong id="trClsCount">0</strong><span>Classes</span></div>
          <div class="stat fade-in"><strong id="trBookCount">0</strong><span>Bookings</span></div>
          <div class="stat fade-in"><strong id="trRating">4.9</strong><span>Avg Rating</span></div>
        </div>
        <div class="panel-head" style="margin-bottom: 16px;">
          <div><h3>Member Profiles</h3><p>Tap a member to see their bookings with you.</p></div>
          <input id="memSearchTr" type="text" placeholder="🔍 Search by name..." style="min-width: 240px;" />
        </div>
        <div id="trainerMembersList" class="dashboard-grid" style="gap: 16px;"></div>
        <div id="trainerMessage" class="notice hidden" style="margin-top: 20px;"></div>
      </section>
    </main>
  </div>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      if (typeof PowerTempleAPI === 'undefined' || typeof auth === 'undefined') return;
      const user = auth.getCurrentUser();
      if (!user) return;
      const trainerRecord = PowerTempleAPI.trainers.find((t) => t.username === user.username) || PowerTempleAPI.trainers[0];
      if (!trainerRecord) return;
      const myClasses = PowerTempleAPI.getTrainerSchedule(trainerRecord.id);
      const myMembers = PowerTempleAPI.getTrainerMembers(trainerRecord.id);
      const myBookings = PowerTempleAPI.bookings.filter((b) => myClasses.some((c) => c.id === b.classId));
      document.getElementById('trMemCount').textContent = myMembers.length;
      document.getElementById('trClsCount').textContent = myClasses.length;
      document.getElementById('trBookCount').textContent = myBookings.length;
      document.getElementById('trRating').textContent = trainerRecord.rating || '4.9';
      function render(filter = '') {
        const list = document.getElementById('trainerMembersList');
        const q = filter.toLowerCase();
        const filtered = myMembers.filter((m) => !q || m.name.toLowerCase().includes(q));
        list.innerHTML = filtered.map((m) => { const bookings = myBookings.filter((b) => b.memberId === m.id); return `<article class="form-card fade-in"><h3 style="margin-bottom: 6px;">${m.avatar || '👤'} ${m.name}</h3><p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 12px;">${m.email} · ${m.membershipTier || 'Member'}</p><div style="display: grid; gap: 6px; font-size: 0.85rem;">${bookings.map((b) => `<div style="padding: 6px; background: rgba(0, 212, 255, 0.08); border-radius: 4px;">✓ ${b.className} — ${b.date} at ${b.time}</div>`).join('') || '<p style="color: var(--text-muted);">No upcoming bookings.</p>'}</div></article>`; }).join('') || '<p style="color: var(--text-muted);">No members booked into your classes yet.</p>';
      }
      document.getElementById('memSearchTr').addEventListener('input', (e) => render(e.target.value));
      render();
    });
  </script>
</body>
</html>
