<%- include('../partials/head') %>
<body data-page="admin">
  <div class="app">
    <%- include('../partials/header-admin', { activePage: 'memberships' }) %>
    <main class="container">
      <%- include('../partials/hero-video') %>
      <section class="dashboard-layout">
        <div class="dashboard-banner fade-in">
          <div><h2>Membership Management</h2><p>Create plans, configure pricing, and manage individual member subscriptions.</p></div>
        </div>

        <div class="dashboard-grid" style="gap: 24px; margin-bottom: 40px;">
          <div class="stack">

            <!-- Create Plan -->
            <div class="form-card fade-in">
              <h3 style="margin-bottom: 16px;">+ Create Membership Plan</h3>
              <form action="/admin/memberships/plan/create" method="POST">
                <div class="field-grid">
                  <label>Plan Name
                    <input name="name" type="text" placeholder="e.g., Premium" required />
                  </label>
                  <label>Monthly Price (LE)
                    <input name="monthlyPrice" type="number" min="0" placeholder="e.g., 199" required />
                  </label>
                </div>
                <button class="btn btn-primary" type="submit" style="width: 100%;">Publish Plan</button>
              </form>
            </div>

            <!-- Existing Plans -->
            <div class="panel-head" style="margin-top: 24px;">
              <div><h3>Existing Plans</h3><p>Edit pricing inline. Changes are saved to the database.</p></div>
            </div>

            <% plans.forEach(function(plan) { %>
              <article class="row-card fade-in" style="margin-bottom: 12px;">
                <div class="row-main">
                  <strong><%= plan.name %></strong>
                  <form action="/admin/memberships/plan/update/<%= plan._id %>" method="POST" style="display: inline-flex; align-items: center; gap: 8px; margin-top: 6px;">
                    <span style="color: var(--text-secondary); font-size: 0.9rem;">LE</span>
                    <input type="number" name="monthlyPrice" value="<%= plan.monthlyPrice %>" min="0" style="width: 90px; padding: 4px 8px;" />
                    <span style="color: var(--text-secondary); font-size: 0.9rem;">/mo</span>
                    <button class="btn btn-secondary" type="submit" style="padding: 6px 14px; font-size: 0.85rem;">Save</button>
                  </form>
                </div>
                <form action="/admin/memberships/plan/delete/<%= plan._id %>" method="POST" onsubmit="return confirm('Remove this plan?')">
                  <button class="btn btn-ghost" type="submit" style="padding: 6px 12px; font-size: 0.85rem; color: var(--danger-color);">Remove</button>
                </form>
              </article>
            <% }) %>

          </div>

          <aside class="panel">
            <h3 style="margin-bottom: 20px;">Plan Stats</h3>
            <div class="stat-grid" style="gap: 12px;">
              <div class="stat"><strong><%= plans.length %></strong><span>Active Plans</span></div>
              <div class="stat">
                <strong>LE <%= plans.reduce(function(s,p){ return s + p.monthlyPrice; }, 0).toLocaleString() %></strong>
                <span>Total Value</span>
              </div>
            </div>
          </aside>
        </div>

        <div id="adminMessage" class="notice hidden" style="margin-top: 20px;"></div>
      </section>
    </main>
  </div>
</body>
</html>
