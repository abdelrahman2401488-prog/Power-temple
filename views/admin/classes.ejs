<%- include('../partials/head') %>
<body data-page="admin">
  <div class="app">
    <%- include('../partials/header-admin', { activePage: 'classes' }) %>
    <main class="container">
      <%- include('../partials/hero-video') %>
      <section class="dashboard-layout">
        <div class="dashboard-banner fade-in">
          <div><h2>Class Management</h2><p>Create, schedule, and manage all group classes. Monitor capacity and member demand.</p></div>
          <a class="btn btn-primary" href="/admin/trainers">Manage Trainers</a>
        </div>

        <div class="dashboard-grid" style="gap: 24px; margin-bottom: 40px;">
          <div class="stack">

            <!-- Create Class Form (server-side POST with image upload) -->
            <div class="form-card fade-in">
              <h3 style="margin-bottom: 16px;">+ Create New Class</h3>
              <form action="/admin/classes" method="POST" enctype="multipart/form-data">

                <label>Class Name
                  <input name="name" type="text" placeholder="e.g., MMA Championship Training" required />
                </label>

                <label>Trainer
                  <select name="trainer" required>
                    <option value="">Select a trainer...</option>
                    <% if (typeof trainers !== 'undefined') { %>
                      <% trainers.forEach(function(t) { %>
                        <option value="<%= t.name %>"><%= t.name %></option>
                      <% }) %>
                    <% } %>
                  </select>
                </label>

                <div class="field-grid">
                  <label>Category
                    <select name="category" required>
                      <option>Cardio</option>
                      <option>Strength</option>
                      <option>Recovery</option>
                      <option>Combat</option>
                    </select>
                  </label>
                  <label>Level
                    <select name="level" required>
                      <option>Beginner</option>
                      <option>Intermediate</option>
                      <option>Advanced</option>
                    </select>
                  </label>
                </div>

                <div class="field-grid">
                  <label>Schedule Time
                    <input name="time" type="text" placeholder="e.g., Mon 7:00 AM" required />
                  </label>
                  <label>Duration (min)
                    <input name="duration" type="number" min="1" placeholder="60" value="60" />
                  </label>
                </div>

                <label>Capacity
                  <input name="capacity" type="number" min="1" placeholder="Max members" required />
                </label>

                <label>Description
                  <textarea name="description" placeholder="Class details and benefits..."></textarea>
                </label>

                <label>Class Photo</label>
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                  <input id="classImageInput" name="image" type="file" accept="image/*" style="display: none;" onchange="document.getElementById('classImageLabel').textContent = this.files[0] ? this.files[0].name : 'No file chosen'" />
                  <button type="button" class="btn btn-secondary" onclick="document.getElementById('classImageInput').click()">
                    Choose Photo
                  </button>
                  <span id="classImageLabel" style="font-size: 0.9rem; color: var(--text-muted);">No file chosen</span>
                </div>

                <button class="btn btn-primary" type="submit" style="width: 100%; margin-top: 8px;">Publish Class</button>
              </form>
            </div>

            <!-- Classes list from MongoDB -->
            <div id="classSection">
            <div class="panel-head" style="margin-top: 24px;">
              <div>
                <h3>All Classes</h3>
                <p><%= typeof classes !== 'undefined' ? classes.length : 0 %> classes in the system</p>
              </div>
            </div>

            <% if (typeof classes !== 'undefined' && classes.length > 0) { %>
              <% classes.forEach(function(cls) { %>
                <article class="class-card fade-in" id="class-<%= cls._id %>" style="margin-bottom: 16px;">
                  <% if (cls.image) { %>
                    <img src="<%= cls.image %>" alt="<%= cls.name %>" style="width: 100%; height: 180px; object-fit: cover; border-radius: 8px; margin-bottom: 12px;" />
                  <% } %>
                  <div class="toolbar">
                    <span class="pill success"><%= cls.category %></span>
                    <span class="pill success" id="capacityPill-<%= cls._id %>"><%= cls.booked %>/<%= cls.capacity %></span>
                  </div>
                  <h3><%= cls.name %></h3>
                  <p><%= cls.description %></p>
                  <div class="meta-row">
                    <span><%= cls.time || 'TBD' %></span>
                    <span><%= cls.trainer %></span>
                    <span><%= cls.level %></span>
                  </div>
                  <div style="display: flex; gap: 10px; margin-top: 10px;">
                    <button type="button" class="btn btn-secondary" style="font-size: 0.85rem;" onclick="toggleEditForm('<%= cls._id %>')">Edit</button>
                    <button type="button" class="btn btn-ghost delete-class-btn" data-class-id="<%= cls._id %>" style="font-size: 0.85rem; color: var(--danger-color);">Delete</button>
                  </div>

                  <!-- Inline Edit Form -->
                  <div id="editForm-<%= cls._id %>" style="display: none; margin-top: 16px; border-top: 1px solid var(--border-color); padding-top: 16px;">
                    <h4 style="margin-bottom: 12px;">Edit Class</h4>
                    <form action="/admin/classes/edit/<%= cls._id %>" method="POST" enctype="multipart/form-data">
                      <label>Class Name
                        <input name="name" type="text" value="<%= cls.name %>" required />
                      </label>
                      <label>Trainer
                        <select name="trainer" required>
                          <% if (typeof trainers !== 'undefined' && trainers.length > 0) { %>
                            <% trainers.forEach(function(t) { %>
                              <option value="<%= t.name %>" <%= cls.trainer === t.name ? 'selected' : '' %>><%= t.name %></option>
                            <% }) %>
                          <% } else { %>
                            <option value="<%= cls.trainer %>" selected><%= cls.trainer %></option>
                          <% } %>
                        </select>
                      </label>
                      <div class="field-grid">
                        <label>Category
                          <select name="category" required>
                            <% ['Cardio','Strength','Recovery','Combat'].forEach(function(cat) { %>
                              <option <%= cls.category === cat ? 'selected' : '' %>><%= cat %></option>
                            <% }) %>
                          </select>
                        </label>
                        <label>Level
                          <select name="level" required>
                            <% ['Beginner','Intermediate','Advanced'].forEach(function(lvl) { %>
                              <option <%= cls.level === lvl ? 'selected' : '' %>><%= lvl %></option>
                            <% }) %>
                          </select>
                        </label>
                      </div>
                      <div class="field-grid">
                        <label>Schedule Time
                          <input name="time" type="text" value="<%= cls.time || '' %>" required />
                        </label>
                        <label>Duration (min)
                          <input name="duration" type="number" min="1" value="<%= cls.duration || 60 %>" />
                        </label>
                      </div>
                      <label>Capacity
                        <input name="capacity" type="number" min="1" value="<%= cls.capacity %>" required />
                      </label>
                      <label>Description
                        <textarea name="description"><%= cls.description %></textarea>
                      </label>
                      <label>Replace Photo (optional)</label>
                      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                        <input id="editImage-<%= cls._id %>" name="image" type="file" accept="image/*" style="display: none;" onchange="document.getElementById('editImageLabel-<%= cls._id %>').textContent = this.files[0] ? this.files[0].name : 'No file chosen'" />
                        <button type="button" class="btn btn-secondary" onclick="document.getElementById('editImage-<%= cls._id %>').click()">Choose Photo</button>
                        <span id="editImageLabel-<%= cls._id %>" style="font-size: 0.9rem; color: var(--text-muted);">No file chosen</span>
                      </div>
                      <div style="display: flex; gap: 10px;">
                        <button class="btn btn-primary" type="submit" style="flex: 1;">Save Changes</button>
                        <button type="button" class="btn btn-ghost" onclick="toggleEditForm('<%= cls._id %>')" style="flex: 1;">Cancel</button>
                      </div>
                    </form>
                  </div>
                </article>
              <% }) %>
            <% } else { %>
              <div class="empty-state">No classes yet. Create one above.</div>
            <% } %>
            </div>

          </div>

          <aside class="panel">
            <h3 style="margin-bottom: 16px;">Deletion Requests
              <% if (typeof deletionRequests !== 'undefined' && deletionRequests.length > 0) { %>
                <span class="pill warning" style="margin-left: 6px;"><%= deletionRequests.length %></span>
              <% } %>
            </h3>
            <% if (typeof deletionRequests !== 'undefined' && deletionRequests.length > 0) { %>
              <% deletionRequests.forEach(function(reqItem) { %>
                <div style="border: 1px solid var(--border-color); border-radius: 8px; padding: 12px; margin-bottom: 12px;">
                  <strong style="display:block;"><%= reqItem.className %></strong>
                  <p style="font-size: 0.85rem; color: var(--text-secondary); margin: 4px 0;">Requested by <%= reqItem.requestedByName || 'a manager' %></p>
                  <% if (reqItem.reason) { %>
                    <p style="font-size: 0.85rem; color: var(--text-muted); margin: 4px 0;">"<%= reqItem.reason %>"</p>
                  <% } %>
                  <div style="display: flex; gap: 8px; margin-top: 8px;">
                    <form action="/admin/class-requests/approve/<%= reqItem._id %>" method="POST" style="flex: 1;" onsubmit="return confirm('Delete this class? This cannot be undone.')">
                      <button type="submit" class="btn btn-primary" style="width: 100%; font-size: 0.8rem;">Approve &amp; Delete</button>
                    </form>
                    <form action="/admin/class-requests/reject/<%= reqItem._id %>" method="POST" style="flex: 1;">
                      <button type="submit" class="btn btn-ghost" style="width: 100%; font-size: 0.8rem;">Reject</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 20px;">No pending deletion requests.</p>
            <% } %>

            <h3 style="margin-bottom: 20px;">Class Stats</h3>
            <div class="stat-grid" style="gap: 12px; margin-bottom: 24px;">
              <div class="stat"><strong><%= typeof classes !== 'undefined' ? classes.length : 0 %></strong><span>Total Classes</span></div>
              <div class="stat"><strong>4.8</strong><span>Avg Rating</span></div>
            </div>
            <div id="adminMessage" class="notice hidden" style="margin-top: 20px;"></div>
          </aside>
        </div>
      </section>
    </main>
  </div>
  <script>
    function toggleEditForm(id) {
      const form = document.getElementById('editForm-' + id);
      form.style.display = form.style.display === 'none' ? 'block' : 'none';
    }

    document.querySelectorAll('.delete-class-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (!confirm('Delete this class?')) return;

        var classId = btn.dataset.classId;
        var card = document.getElementById('class-' + classId);
        btn.disabled = true;
        btn.textContent = 'Deleting...';

        fetch('/admin/classes/delete/' + classId, {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
        })
          .then(function (res) { return res.json(); })
          .then(function (data) {
            if (data.status === 'success') {
              card.style.transition = 'opacity 0.25s ease';
              card.style.opacity = '0';
              setTimeout(function () { card.remove(); }, 250);
            } else {
              alert(data.message || 'Failed to delete class');
              btn.disabled = false;
              btn.textContent = 'Delete';
            }
          })
          .catch(function () {
            alert('Network error. Please try again.');
            btn.disabled = false;
            btn.textContent = 'Delete';
          });
      });
    });
  </script>
</body>
</html>
