<% extraCss = '<link rel="stylesheet" href="/css/index.css" />' %>
<% extraJs = '<script src="/js/index.js" defer></script>' %>
<%- include('partials/head') %>
<body data-page="landing">
  <div class="app">
    <%- include('partials/header-public', { activePage: 'home' }) %>

    <main class="container">
      <section class="hero">
        <div class="hero-video-bg">
          <video class="hero-video-element" autoplay muted loop playsinline aria-hidden="true">
            <source src="/videos/hero-bg.mp4" type="video/mp4">
          </video>
          <div class="hero-video-overlay"></div>
          <div class="hero-video-text" aria-label="Hero message">INHALE PASSION</div>
        </div>
        <section class="hero-story" id="concept" aria-label="Power Temple story">
          <figure class="concept-media">
            <img src="/images/pt.jpeg" alt="Power Temple history collage" loading="lazy" />
          </figure>
          <div class="concept-copy">
            <p>Power Temple kick started in 2017 with a game changing mindset to start an evolution in the fitness industry, setting new benchmarks for rapid and outstanding physical and mental transformations.</p>
            <p>The concept being derived from an Olympic champion and the well-established fitness figure, Lazar Angelov upholds our belief that any transformation starts from within, one trains, disciplines, and strengthens the mind first to boost the body's activity to unlock your highest performance.</p>
            <p>We strive to influence our clients to do better in all aspects of life as we believe that our membership is not just about a room full equipment. It's providing a better and healthier lifestyle.</p>
          </div>
        </section>
        <div class="hero-grid">
          <div class="hero-copy fade-in">
            <span class="eyebrow">Revolutionize Your Fitness</span>
            <h1>Train Like a Champion. Dominate Your Goals.</h1>
            <p>Join thousands of elite athletes using Power Temple. Real-time coaching from certified trainers, advanced analytics, and a community obsessed with excellence. Your transformation starts now.</p>
            <div class="hero-actions">
              <a class="btn btn-primary" href="#login" data-open-login-modal>Start Your Journey</a>
              <a class="btn btn-secondary" href="/member/browse-classes">Explore Classes</a>
            </div>
            <div class="chip-row">
              <span class="pill success">Live Trainers 24/7</span>
              <span class="pill success">400+ Premium Classes</span>
              <span class="pill success">Expert Community</span>
            </div>
          </div>
          <aside class="hero-card fade-in">
            <div class="stat-grid">
              <div class="stat"><strong data-landing-stat="classes">50+</strong><span>Classes Weekly</span></div>
              <div class="stat"><strong data-landing-stat="trainers">25+</strong><span>Expert Trainers</span></div>
              <div class="stat"><strong data-landing-stat="bookings">2.5K</strong><span>Active Members</span></div>
              <div class="stat"><strong data-landing-stat="spots">847</strong><span>Spots Available</span></div>
            </div>
          </aside>
        </div>
      </section>

      <section class="section fade-in" id="classes-preview">
        <div class="section-head">
          <div>
            <h2 class="classes-carousel-title">OUR <span>CLASSES</span></h2>
            <p>Elite training programs crafted by world-class coaches</p>
          </div>
          <a class="btn btn-secondary" href="/member/browse-classes">View All Classes →</a>
        </div>
        <div class="classes-carousel-wrap">
          <div class="classes-carousel-track" id="classesCarousel">
            <% (classes || []).forEach(function(cls) { %>
            <div class="classes-slide-card">
              <div class="slide-img-wrap">
                <img src="<%= cls.image || '/images/mobility-flow.jpg' %>" alt="<%= cls.name %>" />
                <div class="slide-overlay"></div>
                <div class="slide-badges">
                  <% (cls.badges || [cls.category]).forEach(function(b) { %>
                    <span class="pill success"><%= b %></span>
                  <% }) %>
                </div>
              </div>
              <div class="slide-info">
                <h3><%= cls.name %></h3>
                <p><%= cls.description %></p>
                <div class="slide-meta">
                  <span>⏱ <%= cls.duration %> min</span>
                  <span>👥 Max <%= cls.capacity %> members</span>
                </div>
                <a href="/member/browse-classes" class="btn btn-primary" data-require-auth>Book Class →</a>
              </div>
            </div>
            <% }) %>
            <% if (!classes || classes.length === 0) { %>
            <div class="classes-slide-card">
              <div class="slide-info" style="padding: 40px; text-align: center;">
                <h3>Classes coming soon</h3>
                <p>Check back soon for our elite training programs.</p>
              </div>
            </div>
            <% } %>
            </div>
          </div>
          <button class="carousel-btn carousel-btn-prev" id="carouselPrev" aria-label="Previous">&#8592;</button>
          <button class="carousel-btn carousel-btn-next" id="carouselNext" aria-label="Next">&#8594;</button>
        </div>
        <div class="carousel-dots" id="carouselDots">
          <% (classes || []).forEach(function(cls, i) { %>
            <button class="carousel-dot <%= i === 0 ? 'active' : '' %>" data-idx="<%= i %>"></button>
          <% }) %>
          <% if (!classes || classes.length === 0) { %>
            <button class="carousel-dot active" data-idx="0"></button>
          <% } %>
        </div>
      </section>

      <section class="section fade-in" style="flex-direction: column; align-items: center; text-align: center; padding: 60px 20px;">
        <div>
          <h2>Ready to Transform?</h2>
          <p>Join 2,500+ athletes who've already started their journey with Power Temple. Your best self is waiting.</p>
        </div>
        <a class="btn btn-primary" style="margin-top: 24px;" href="/auth/register">Get Started Free</a>
      </section>

      <%- include('partials/footer') %>
    </main>
  </div>

  <%- include('partials/cart-drawer') %>
  <%- include('partials/login-modal') %>
  <script>
    document.querySelectorAll('[data-require-auth]').forEach(function(link) {
      link.addEventListener('click', function(e) {
        <% if (!locals.sessionUser) { %>
        e.preventDefault();
        // Show notification
        var n = document.createElement('div');
        n.textContent = 'You need to sign in to book a class.';
        n.style.cssText = 'position:fixed;top:24px;right:24px;z-index:9999;background:#1a1a2e;color:#fff;padding:14px 20px;border-radius:10px;border-left:4px solid #00d4ff;font-size:0.95rem;box-shadow:0 4px 20px rgba(0,0,0,0.4);';
        document.body.appendChild(n);
        setTimeout(function() {
          window.location.href = '/auth/register#register';
        }, 1800);
        setTimeout(function() { n.remove(); }, 4000);
        <% } %>
      });
    });
  </script>
</body>
</html>
