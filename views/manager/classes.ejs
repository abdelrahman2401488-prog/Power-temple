<%- include('../partials/head') %>
<body data-page="manager">
  <div class="app">
    <%- include('../partials/header-manager', { activePage: 'classes' }) %>
    <main class="container">
      <%- include('../partials/hero-video') %>
      <section class="dashboard-layout">
        <div class="dashboard-banner fade-in">
          <div><h2>Class & Trainer Scheduling</h2><p>Create classes, assign trainers, set capacity, and update trainer info.</p></div>
        </div>

        <div class="dashboard-grid" style="gap: 24px; margin-bottom: 32px;">

          <!-- Left: Create Class + Class List -->
          <div class="stack">
            <div class="form-card fade-in">
              <h3 style="margin-bottom: 16px;">+ Create / Schedule Class</h3>
              <form action="/manager/classes" method="POST" enctype="multipart/form-data">
                <label>Class Name
                  <input name="name" type="text" placeholder="e.g., Morning HIIT" required />
                </label>

                <div class="field-grid">
                  <label>Trainer
                    <select name="trainerId" required style="width: 100%;">
                      <option value="">Select trainer...</option>
                      <% trainers.forEach(function(t) { %>
                        <option value="<%= t._id %>"><%= t.name %></option>
                      <% }) %>
                      <% if (trainers.length === 0) { %>
                        <option disabled>No trainers added yet</option>
                      <% } %>
                    </select>
                  </label>
                  <label>Room
                    <input name="room" type="text" placeholder="Studio A" required />
                  </label>
                </div>

                <div class="field-grid">
                  <label>Time
                    <input name="time" type="text" placeholder="06:00 AM" required />
                  </label>
                  <label>Capacity
                    <input name="capacity" type="number" min="1" max="100" required />
                  </label>
                </div>

                <div class="field-grid">
                  <label>Category
                    <select name="category" style="width: 100%;">
                      <option>Cardio</option><option>Strength</option><option>Recovery</option><option>Combat</option>
                    </select>
                  </label>
                  <label>Level
                    <select name="level" style="width: 100%;">
                      <option>Beginner</option><option>Intermediate</option><option>Advanced</option>
                    </select>
                  </label>
                </div>

                <label>Description
                  <textarea name="description" placeholder="What members can expect..."></textarea>
                </label>

                <label>Class Photo</label>
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                  <input id="classImageInput" name="image" type="file" accept="image/*" style="display: none;" onchange="document.getElementById('classImageLabel').textContent = this.files[0] ? this.files[0].name : 'No file chosen'" />
                  <button type="button" class="btn btn-secondary" onclick="document.getElementById('classImageInput').click()">Choose Photo</button>
                  <span id="classImageLabel" style="font-size: 0.9rem; color: var(--text-muted);">No file chosen</span>
                </div>

                <button class="btn btn-primary" type="submit" style="width: 100%;">Publish Class</button>
              </form>
            </div>

            <!-- Classes list -->
            <div id="classSection">
            <div class="panel-head" style="margin-top: 24px;">
              <div><h3>Scheduled Classes</h3><p><%= classes.length %> class<%= classes.length !== 1 ? 'es' : '' %> in the system</p></div>
            </div>

            <% if (classes.length > 0) { %>
              <div id="managerClassList">
              <% classes.forEach(function(cls) { %>
                <% var isPending = pendingDeletions.indexOf(String(cls._id)) !== -1; %>
                <article class="class-card fade-in" id="class-<%= cls._id %>" style="margin-bottom: 16px;">
                  <% if (cls.image) { %>
                    <img src="<%= cls.image %>" alt="<%= cls.name %>" style="width: 100%; height: 180px; object-fit: cover; border-radius: 8px; margin-bottom: 12px;" />
                  <% } %>
                  <div class="toolbar">
                    <span class="pill success"><%= cls.category %></span>
                    <span class="pill success" id="capacityPill-<%= cls._id %>"><%= cls.booked %>/<%= cls.capacity %></span>
                    <% if (isPending) { %><span class="pill warning">Deletion pending admin</span><% } %>
                  </div>
                  <h3><%= cls.name %></h3>
                  <p><%= cls.description %></p>
                  <div class="meta-row">
                    <span><%= cls.time || 'TBD' %></span>
                    <span><%= cls.trainer %></span>
                    <span><%= cls.room || '' %></span>
                    <span><%= cls.level %></span>
                  </div>

                  <div style="display: flex; gap: 10px; margin-top: 10px; align-items: center;">
                    <button type="button" class="btn btn-secondary" style="font-size: 0.85rem;" onclick="toggleEditForm('<%= cls._id %>')">Edit</button>
                    <% if (isPending) { %>
                      <span style="font-size: 0.85rem; color: var(--warning-color);">Awaiting admin approval to delete</span>
                    <% } else { %>
                      <button type="button" class="btn btn-ghost" style="font-size: 0.85rem; color: var(--danger-color);" onclick="toggleDeleteForm('<%= cls._id %>')">Request Deletion</button>
                    <% } %>
                  </div>

                  <!-- Request Deletion form -->
                  <% if (!isPending) { %>
                  <form id="deleteForm-<%= cls._id %>" action="/manager/classes/request-delete/<%= cls._id %>" method="POST" style="display: none; margin-top: 12px; border-top: 1px solid var(--border-color); padding-top: 12px;">
                    <label style="font-size: 0.9rem;">Reason for deletion (sent to admin)
                      <textarea name="reason" placeholder="Why should this class be removed?" style="width: 100%; min-height: 50px;"></textarea>
                    </label>
                    <div style="display: flex; gap: 10px;">
                      <button class="btn btn-primary" type="submit" style="flex: 1;">Send Request to Admin</button>
                      <button type="button" class="btn btn-ghost" onclick="toggleDeleteForm('<%= cls._id %>')" style="flex: 1;">Cancel</button>
                    </div>
                  </form>
                  <% } %>

                  <!-- Inline Edit Form -->
                  <div id="editForm-<%= cls._id %>" style="display: none; margin-top: 16px; border-top: 1px solid var(--border-color); padding-top: 16px;">
                    <h4 style="margin-bottom: 12px;">Edit Class</h4>
                    <form action="/manager/classes/edit/<%= cls._id %>" method="POST" enctype="multipart/form-data">
                      <label>Class Name
                        <input name="name" type="text" value="<%= cls.name %>" required />
                      </label>
                      <div class="field-grid">
                        <label>Trainer
                          <select name="trainerId" required style="width: 100%;">
                            <% trainers.forEach(function(t) { %>
                              <option value="<%= t._id %>" <%= String(cls.trainerId) === String(t._id) ? 'selected' : '' %>><%= t.name %></option>
                            <% }) %>
                          </select>
                        </label>
                        <label>Room
                          <input name="room" type="text" value="<%= cls.room || '' %>" required />
                        </label>
                      </div>
                      <div class="field-grid">
                        <label>Time
                          <input name="time" type="text" value="<%= cls.time || '' %>" required />
                        </label>
                        <label>Capacity
                          <input name="capacity" type="number" min="1" max="100" value="<%= cls.capacity %>" required />
                        </label>
                      </div>
                      <div class="field-grid">
                        <label>Category
                          <select name="category" style="width: 100%;">
                            <% ['Cardio','Strength','Recovery','Combat'].forEach(function(cat) { %>
                              <option <%= cls.category === cat ? 'selected' : '' %>><%= cat %></option>
                            <% }) %>
                          </select>
                        </label>
                        <label>Level
                          <select name="level" style="width: 100%;">
                            <% ['Beginner','Intermediate','Advanced'].forEach(function(lvl) { %>
                              <option <%= cls.level === lvl ? 'selected' : '' %>><%= lvl %></option>
                            <% }) %>
                          </select>
                        </label>
                      </div>
                      <label>Description
                        <textarea name="description"><%= cls.description %></textarea>
                      </label>
                      <label>Replace Photo (optional)</label>
                      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                        <input id="editImage-<%= cls._id %>" name="image" type="file" accept="image/*" style="display: none;" onchange="document.getElementById('editImageLabel-<%= cls._id %>').textContent = this.files[0] ? this.files[0].name : 'No file chosen'" />
                        <button type="button" class="btn btn-secondary" onclick="document.getElementById('editImage-<%= cls._id %>').click()">Choose Photo</button>
                        <span id="editImageLabel-<%= cls._id %>" style="font-size: 0.9rem; color: var(--text-muted);">No file chosen</span>
                      </div>
                      <div style="display: flex; gap: 10px;">
                        <button class="btn btn-primary" type="submit" style="flex: 1;">Save Changes</button>
                        <button type="button" class="btn btn-ghost" onclick="toggleEditForm('<%= cls._id %>')" style="flex: 1;">Cancel</button>
                      </div>
                    </form>
                  </div>
                </article>
              <% }) %>
              </div>
            <% } else { %>
              <div class="empty-state">No classes yet. Create one above.</div>
            <% } %>
            </div>
          </div>

          <!-- Right: Edit Trainer Info -->
          <aside class="panel" style="height: fit-content;">
            <h3 style="margin-bottom: 16px;">Edit Trainer Info</h3>

            <% if (trainers.length > 0) { %>
              <% trainers.forEach(function(t) { %>
                <details style="margin-bottom: 12px; border: 1px solid var(--border-color); border-radius: 8px; padding: 12px;">
                  <summary style="cursor: pointer; font-weight: 600; color: var(--text-primary);"><%= t.name %></summary>
                  <form action="/manager/trainer/update/<%= t._id %>" method="POST" style="margin-top: 12px; display: grid; gap: 10px;">
                    <label style="font-size: 0.9rem;">Specialty
                      <input type="text" name="specialty" value="<%= t.specialty || '' %>" style="width: 100%;" />
                    </label>
                    <label style="font-size: 0.9rem;">Bio
                      <textarea name="bio" style="width: 100%; min-height: 60px;"><%= t.bio || '' %></textarea>
                    </label>
                    <button type="submit" class="btn btn-primary" style="width: 100%;">Save Changes</button>
                  </form>
                </details>
              <% }) %>
            <% } else { %>
              <p style="color: var(--text-muted); font-size: 0.9rem;">No trainers added yet. Ask admin to add trainers first.</p>
            <% } %>
          </aside>

        </div>
      </section>
    </main>
  </div>
  <script>
    function toggleEditForm(id) {
      var form = document.getElementById('editForm-' + id);
      form.style.display = form.style.display === 'none' ? 'block' : 'none';
    }
    function toggleDeleteForm(id) {
      var form = document.getElementById('deleteForm-' + id);
      if (form) form.style.display = form.style.display === 'none' ? 'block' : 'none';
    }
  </script>
</body>
</html>
