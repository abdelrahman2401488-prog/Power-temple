<%- include('../partials/head') %>
<body data-page="manager">
  <div class="app">
    <%- include('../partials/header-manager', { activePage: 'dashboard' }) %>
    <main class="container">
      <%- include('../partials/hero-video') %>
      <section class="dashboard-layout">
        <div class="dashboard-banner fade-in">
          <div><h2>Branch Manager Control Center</h2><p>Run the day-to-day operations. Register members, schedule classes, log payments, and review reports.</p></div>
          <a class="btn btn-primary" href="/manager/members">Register Member</a>
        </div>
        <div class="dashboard-grid" style="gap: 24px; margin-bottom: 32px;">
          <div class="stack">
            <div class="panel-head"><div><h3>Quick Operations</h3><p>Get to the most common manager tasks fast.</p></div></div>
            <div class="feature-grid stagger">
              <a class="feature-card" href="/manager/members"><h3>Register Member</h3><p>Onboard new walk-ins with full membership setup.</p></a>
              <a class="feature-card" href="/manager/classes"><h3>Create / Schedule Class</h3><p>Assign trainers, set capacity, publish sessions.</p></a>
              <a class="feature-card" href="/manager/payments"><h3>Record Cash Payment</h3><p>Log walk-in renewals and cash transactions.</p></a>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
