<%- include('../partials/head') %>
<body data-page="manager">
  <div class="app">
    <%- include('../partials/header-manager', { activePage: 'members' }) %>
    <main class="container">
      <%- include('../partials/hero-video') %>
      <section class="dashboard-layout">
        <div class="dashboard-banner fade-in">
          <div><h2>Member Management</h2><p>Register new members, update info, renew memberships, and suspend accounts.</p></div>
        </div>

        <% if (locals.flash) { %>
          <div class="notice" style="margin-bottom: 16px; padding: 12px 16px; background: rgba(0,212,255,0.1); border-left: 3px solid var(--primary-color); border-radius: 6px; color: var(--primary-color);">
            <%= flash %>
          </div>
        <% } %>

        <div class="dashboard-grid" style="gap: 24px; margin-bottom: 32px;">
          <div class="stack">

            <!-- Register New Member -->
            <div class="form-card fade-in">
              <h3 style="margin-bottom: 16px;">+ Register New Member</h3>
              <form action="/manager/members/register" method="POST">
                <div class="field-grid">
                  <label>Full Name<input name="name" type="text" required /></label>
                  <label>Email<input name="email" type="email" required /></label>
                </div>
                <div class="field-grid">
                  <label>Username<input name="username" type="text" required /></label>
                  <label>Initial Password<input name="password" type="text" value="TempPass1" required /></label>
                </div>
                <div class="field-grid">
                  <label>Plan
                    <select name="tier" required>
                      <option value="Starter">Starter</option>
                      <option value="Elite">Elite</option>
                      <option value="Pro">Pro</option>
                      <option value="Champion">Champion</option>
                    </select>
                  </label>
                  <label>Branch
                    <select name="branch" required>
                      <option>Maadi</option>
                      <option>Zamalek</option>
                      <option>New Cairo</option>
                    </select>
                  </label>
                </div>
                <button class="btn btn-primary" type="submit" style="width: 100%;">Register Member</button>
              </form>
            </div>

            <!-- Search -->
            <form method="GET" action="/manager/members" style="margin-top: 24px;">
              <input name="q" type="text" value="<%= locals.q || '' %>" placeholder="🔍 Search members..." style="width: 100%; margin-bottom: 20px;" oninput="this.form.submit()" />
            </form>

            <% var memberList = locals.members || []; %>
            <% var searchQ = locals.q || ''; %>

            <!-- Members List -->
            <div id="memberSection">
            <div class="panel-head">
              <div>
                <h3>Members</h3>
                <p><%= memberList.length %> member<%= memberList.length !== 1 ? 's' : '' %> found</p>
              </div>
            </div>

            <% if (memberList.length > 0) { %>
              <div id="memberList">
              <% memberList.forEach(function(m) { %>
                <%
                  var statusPill = 'success';
                  if (m.membershipStatus === 'suspended' || m.membershipStatus === 'cancelled') statusPill = 'danger';
                  else if (m.membershipStatus === 'frozen') statusPill = 'warning';
                %>
                <article class="row-card fade-in" id="user-<%= m._id %>" style="margin-bottom: 12px;">
                  <div class="row-main">
                    <strong>👤 <%= m.name %></strong>
                    <span class="row-meta">@<%= m.username %> · <%= m.membershipTier || 'No plan' %> · joined <%= m.joiningDate ? m.joiningDate.toISOString().split('T')[0] : '—' %></span>
                    <span class="row-meta"><%= m.email %></span>
                  </div>
                  <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-top: 10px;">
                    <span class="pill <%= statusPill %>" id="statusPill-<%= m._id %>"><%= m.membershipStatus || 'active' %></span>

                    <form action="/manager/members/renew/<%= m._id %>" method="POST" style="margin: 0;">
                      <button class="btn btn-secondary" type="submit" style="padding: 6px 12px; font-size: 0.85rem;">Renew</button>
                    </form>

                    <% if (m.membershipStatus !== 'suspended') { %>
                      <form action="/manager/members/suspend/<%= m._id %>" method="POST" style="margin: 0;">
                        <button class="btn btn-secondary" type="submit" style="padding: 6px 12px; font-size: 0.85rem;" onclick="return confirm('Suspend <%= m.name %>?')">Suspend</button>
                      </form>
                    <% } %>

                    <% if (m.membershipStatus !== 'active') { %>
                      <form action="/manager/members/activate/<%= m._id %>" method="POST" style="margin: 0;">
                        <button class="btn btn-ghost" type="submit" style="padding: 6px 12px; font-size: 0.85rem;">Activate</button>
                      </form>
                    <% } %>
                  </div>
                </article>
              <% }) %>
              </div>
            <% } else { %>
              <div class="empty-state">No members found<%= searchQ ? ' matching "' + searchQ + '"' : '' %>.</div>
            <% } %>
            </div>

          </div>

          <!-- Stats Sidebar -->
          <aside class="panel">
            <h3 style="margin-bottom: 16px;">Member Stats</h3>
            <div class="stat-grid" style="gap: 12px;">
              <div class="stat"><strong><%= memberList.length %></strong><span>Total</span></div>
              <div class="stat"><strong><%= memberList.filter(function(m){ return m.membershipStatus === 'active'; }).length %></strong><span>Active</span></div>
              <div class="stat"><strong><%= memberList.filter(function(m){ return m.membershipStatus === 'suspended'; }).length %></strong><span>Suspended</span></div>
              <div class="stat">
                <strong><%=
                  memberList.filter(function(m){
                    return m.joiningDate && (Date.now() - new Date(m.joiningDate).getTime()) < 30 * 24 * 60 * 60 * 1000;
                  }).length
                %></strong>
                <span>New (30d)</span>
              </div>
            </div>
          </aside>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
