<%- include('../partials/head') %>
<body data-page="manager">
  <div class="app">
    <%- include('../partials/header-manager', { activePage: 'payments' }) %>
    <main class="container">
      <%- include('../partials/hero-video') %>
      <section class="dashboard-layout">
        <div class="dashboard-banner fade-in"><div><h2>Payments & Transactions</h2><p>Record cash payments, view all transactions, and track membership renewals.</p></div></div>
        <div class="dashboard-grid" style="gap: 24px; margin-bottom: 32px;">
          <div class="stack">
            <div class="form-card fade-in">
              <h3 style="margin-bottom: 16px;">+ Record Payment</h3>
              <form action="/manager/payments" method="POST">
                <label>Member
                  <select name="memberId" required style="width: 100%;">
                    <option value="">Select member...</option>
                    <% members.forEach(function(m) { %>
                      <option value="<%= m._id %>"><%= m.name %> (<%= m.email %>)</option>
                    <% }) %>
                    <% if (members.length === 0) { %><option disabled>No members yet</option><% } %>
                  </select>
                </label>
                <div class="field-grid">
                  <label>Amount (LE)<input name="amount" type="number" min="1" required /></label>
                  <label>Method
                    <select name="method" style="width: 100%;">
                      <option value="cash">Cash</option>
                      <option value="card">Card</option>
                    </select>
                  </label>
                </div>
                <label>Description<input name="description" type="text" placeholder="e.g., Elite Renewal" required /></label>
                <button class="btn btn-primary" type="submit" style="width: 100%;">Record Payment</button>
              </form>
            </div>
            <div class="panel-head" style="margin-top: 24px;"><div><h3>Recent Transactions</h3><p><%= payments.length %> recent payment<%= payments.length !== 1 ? 's' : '' %> through the branch.</p></div></div>
            <% if (payments.length > 0) { %>
              <% payments.forEach(function(p) { %>
                <article class="row-card fade-in" style="margin-bottom: 12px;">
                  <div class="row-main">
                    <strong><%= p.memberName || 'Member' %> — LE <%= Number(p.amount).toLocaleString() %></strong>
                    <span class="row-meta"><%= new Date(p.paidAt).toLocaleString() %> · <%= p.method.toUpperCase() %> · <%= p.description %></span>
                  </div>
                  <span class="pill <%= p.status === 'paid' ? 'success' : 'warning' %>"><%= p.status %></span>
                </article>
              <% }) %>
            <% } else { %>
              <div class="empty-state">No payments recorded yet.</div>
            <% } %>
          </div>
          <aside class="panel">
            <h3 style="margin-bottom: 16px;">Payment Stats</h3>
            <div class="stat-grid" style="gap: 12px;">
              <div class="stat"><strong><%= stats.cashCount %></strong><span>Cash Txns</span></div>
              <div class="stat"><strong><%= stats.cardCount %></strong><span>Card Txns</span></div>
              <div class="stat"><strong>LE <%= stats.totalToday.toLocaleString() %></strong><span>Total Today</span></div>
              <div class="stat"><strong>LE <%= stats.totalCollected.toLocaleString() %></strong><span>Total Collected</span></div>
            </div>
          </aside>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
