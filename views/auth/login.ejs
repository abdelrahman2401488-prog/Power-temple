<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Sora:wght@300;400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/variable.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/dashboard.css" />
  <link rel="stylesheet" href="/css/responsive.css" />
  <link rel="stylesheet" href="/css/pro-theme.css" />
</head>
<style>
  .auth-tabs { display: flex; gap: 8px; margin-bottom: 24px; border-bottom: 1px solid var(--border-color); }
  .auth-tab { flex: 1; padding: 12px; background: transparent; color: var(--text-secondary); border: none; font-weight: 600; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s; font-size: 0.95rem; }
  .auth-tab.active { color: var(--primary-color); border-bottom-color: var(--primary-color); }
  .auth-pane { display: none; }
  .auth-pane.active { display: block; animation: fadeInUp 0.4s ease-out; }
  .role-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 16px; }
  .role-btn { padding: 10px 4px; background: var(--glass); color: var(--text-secondary); border: 1px solid var(--border-color); border-radius: 8px; cursor: pointer; font-size: 0.85rem; transition: all 0.2s; text-align: center; }
  .role-btn.active { background: var(--primary-color); color: var(--bg-primary); border-color: var(--primary-color); font-weight: 700; }
  .demo-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 16px; }
  .demo-btn { padding: 8px 4px; background: rgba(0, 212, 255, 0.08); color: var(--primary-color); border: 1px dashed var(--primary-color); border-radius: 8px; cursor: pointer; font-size: 0.75rem; }
  .demo-btn:hover { background: rgba(0, 212, 255, 0.18); }
</style>
<body data-page="login">
  <div class="app">
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/"><span class="brand-mark">PT</span><span>Power Temple</span></a>
        <nav class="nav">
          <a href="/">Home</a>
          <a class="active" href="/auth/login">Sign In</a>
        </nav>
      </div>
    </header>

    <main class="container login-grid">
      <section class="hero-copy fade-in login-side">
        <span class="eyebrow">Welcome Back</span>
        <h1>Train Like a Champion</h1>
        <p>Sign in or create your Power Temple account to book elite classes, manage your membership, and connect with world-class trainers.</p>
        <div class="chip-row">
          <span class="pill success">Secure Login</span>
          <span class="pill success">4 Role Types</span>
          <span class="pill success">Instant Access</span>
        </div>
        <div class="hero-actions"><a class="btn btn-ghost" href="/">← Back to Home</a></div>
      </section>

      <section class="form-card login-panel fade-in">
        <% if (locals.flash) { %>
          <div style="padding: 12px; background: rgba(0,212,255,0.1); border-left: 3px solid #00d4ff; border-radius: 6px; margin-bottom: 16px; color: #00d4ff;">
            ⚠️ <%= flash %>
          </div>
        <% } %>
        <% if (error) { %>
          <div style="padding: 12px; background: rgba(255,0,110,0.1); border-left: 3px solid var(--danger-color); border-radius: 6px; margin-bottom: 16px; color: var(--danger-color);">
            <%= error %>
          </div>
        <% } %>

        <div class="auth-tabs" role="tablist">
          <button type="button" class="auth-tab active" data-tab="login">Sign In</button>
          <button type="button" class="auth-tab" data-tab="register">Create Account</button>
        </div>

        <div class="auth-pane active" id="paneLogin">
          <div style="margin-bottom: 20px;">
            <span class="eyebrow">Sign In</span>
            <h2>Welcome Back</h2>
            <p>Access your dashboard, classes, and personalized training plan.</p>
          </div>
          <form id="loginForm" method="POST" action="/auth/login">
            <label>
              I am a...
              <div class="role-grid" id="loginRoleGrid">
                <button type="button" class="role-btn active" data-role="">Any</button>
                <button type="button" class="role-btn" data-role="member">Member</button>
                <button type="button" class="role-btn" data-role="trainer">Trainer</button>
                <button type="button" class="role-btn" data-role="manager">Manager</button>
              </div>
              <input type="hidden" id="loginRole" name="role" value="" />
            </label>
            <label>
              Username or Email
              <input name="username" type="text" placeholder="your.username or you@email.com" required />
            </label>
            <label>
              Password
              <input name="password" type="password" placeholder="••••••••" required />
            </label>
            <button class="btn btn-primary" type="submit" style="width: 100%;">Sign In</button>
          </form>
          <p style="margin-top: 20px; font-size: 0.9rem; color: var(--text-secondary); text-align: center;">
            New here? <button type="button" class="btn-link" data-switch-tab="register" style="color: var(--primary-color); background: none; border: none; cursor: pointer; font-weight: 600;">Create an account</button>
          </p>
        </div>

        <div class="auth-pane" id="paneRegister">
          <div style="margin-bottom: 20px;">
            <span class="eyebrow">Create Account</span>
            <h2>Begin Your Journey</h2>
            <p>Join Power Temple in 60 seconds. Members get full access to classes, trainers, and the community.</p>
          </div>
          <form id="registerForm" method="POST" action="/auth/register">
            <div class="field-grid">
              <label>Full Name<input name="name" type="text" placeholder="Your full name" required /></label>
              <label>Email Address<input name="email" type="email" placeholder="you@example.com" required /></label>
            </div>
            <label>Username<input name="username" type="text" placeholder="your.username" required /></label>
            <label>Password<input name="password" type="password" placeholder="At least 8 chars, A-Z, a-z, 0-9" required /></label>
            <label>Confirm Password<input id="registerConfirm" name="confirmPassword" type="password" placeholder="••••••••" required /></label>
            <label style="display: flex; align-items: center; gap: 12px; margin: 16px 0;">
              <input id="registerTerms" type="checkbox" required style="width: auto;" />
              <span style="color: var(--text-secondary); font-size: 0.9rem;">
                I agree to Power Temple's <a href="#" style="color: var(--primary-color);">Terms</a> and <a href="#" style="color: var(--primary-color);">Privacy Policy</a>
              </span>
            </label>
            <button class="btn btn-primary" type="submit" style="width: 100%;">Create My Account</button>
          </form>
          <p style="margin-top: 20px; font-size: 0.9rem; color: var(--text-secondary); text-align: center;">
            Already a member? <button type="button" class="btn-link" data-switch-tab="login" style="color: var(--primary-color); background: none; border: none; cursor: pointer; font-weight: 600;">Sign in here</button>
          </p>
        </div>
      </section>
    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const tabs = document.querySelectorAll('.auth-tab');
      const panes = document.querySelectorAll('.auth-pane');
      function switchTab(name) {
        tabs.forEach((t) => t.classList.toggle('active', t.dataset.tab === name));
        panes.forEach((p) => p.classList.toggle('active', p.id === 'pane' + name.charAt(0).toUpperCase() + name.slice(1)));
      }
      tabs.forEach((t) => t.addEventListener('click', () => switchTab(t.dataset.tab)));
      document.querySelectorAll('[data-switch-tab]').forEach((btn) => btn.addEventListener('click', () => switchTab(btn.dataset.switchTab)));

      const roleButtons = document.querySelectorAll('#loginRoleGrid .role-btn');
      const roleInput = document.getElementById('loginRole');
      roleButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          roleButtons.forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          roleInput.value = btn.dataset.role;
        });
      });

      if (window.location.hash === '#register') switchTab('register');
    });
  </script>
</body>
</html>
