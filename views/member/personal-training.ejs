<%- include('../partials/head') %>
<body data-page="member">
  <div class="app">
    <%- include('../partials/header-member', { activePage: 'personal-training' }) %>
    <main class="container">
      <%- include('../partials/hero-video') %>
      <section class="dashboard-layout">
        <div class="dashboard-banner fade-in"><div><h2>Personal Training</h2><p>Request a 1-on-1 session with one of our elite trainers. Pick a date, time, and goal.</p></div></div>
        <div class="dashboard-grid" style="gap: 24px;">
          <div class="form-card fade-in">
            <h3 style="margin-bottom: 16px;">Request a Session</h3>
            <form id="ptForm">
              <label>Trainer<select id="ptTrainer" required></select></label>
              <div class="field-grid">
                <label>Date<input id="ptDate" type="date" required /></label>
                <label>Time<input id="ptTime" type="time" required /></label>
              </div>
              <label>Session Type<select id="ptType" required><option>Strength</option><option>Cardio</option><option>Mobility</option><option>Combat</option><option>Weight Loss</option><option>Muscle Gain</option></select></label>
              <label>Notes (Goals, injuries, preferences)<textarea id="ptNotes" placeholder="Tell your trainer what you want to focus on..."></textarea></label>
              <button class="btn btn-primary" type="submit" style="width: 100%;">Request Session</button>
            </form>
          </div>
          <aside class="panel">
            <h3 style="margin-bottom: 16px;">Featured Trainers</h3>
            <div id="trainerCards" style="display: grid; gap: 12px;"></div>
          </aside>
        </div>
        <div class="panel-head" style="margin: 32px 0 16px;"><div><h3>My Scheduled Sessions</h3><p>Track the status of your personal training requests.</p></div></div>
        <div id="ptList"></div>
        <div id="adminMessage" class="notice hidden" style="margin-top: 20px;"></div>
      </section>
    </main>
  </div>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      if (typeof PowerTempleAPI === 'undefined' || typeof auth === 'undefined') return;
      const user = auth.getCurrentUser();
      if (!user) return;
      const trainerSel = document.getElementById('ptTrainer');
      trainerSel.innerHTML = PowerTempleAPI.trainers.map((t) => `<option value="${t.id}">${t.name} — ${t.specialty}</option>`).join('');
      const cards = document.getElementById('trainerCards');
      cards.innerHTML = PowerTempleAPI.trainers.slice(0, 3).map((t) => `<article style="padding: 12px; background: var(--glass); border-radius: 8px;"><strong>${t.name}</strong><p style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 4px;">${t.specialty} · ⭐ ${t.rating}</p></article>`).join('');
      function renderRequests() {
        const list = document.getElementById('ptList');
        const requests = PowerTempleAPI.getMemberPersonalRequests(user.id);
        list.innerHTML = requests.map((r) => `<article class="row-card fade-in" style="margin-bottom: 12px;"><div class="row-main"><strong>${r.sessionType} with ${r.trainerName}</strong><span class="row-meta">${r.date} at ${r.time}${r.notes ? ' · ' + r.notes : ''}</span></div><span class="pill ${r.status === 'confirmed' ? 'success' : (r.status === 'pending' ? 'warning' : 'danger')}">${r.status}</span></article>`).join('') || '<p style="color: var(--text-muted);">No personal training sessions yet. Request one above!</p>';
      }
      document.getElementById('ptForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const date = document.getElementById('ptDate').value;
        const time = document.getElementById('ptTime').value;
        if (!date || !time) { showNotification('Date and time are required', 'error'); return; }
        PowerTempleAPI.createPersonalTrainingRequest({ memberId: user.id, trainerId: trainerSel.value, sessionType: document.getElementById('ptType').value, date, time, notes: document.getElementById('ptNotes').value });
        showNotification('Personal training session requested! Trainer will confirm shortly.', 'success');
        e.target.reset(); renderRequests();
      });
      renderRequests();
    });
  </script>
</body>
</html>
