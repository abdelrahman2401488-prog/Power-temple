<%- include('../partials/head') %>
<body data-page="memberships">
  <div class="app">
    <% if (locals.sessionUser && sessionUser.role === 'member') { %>
      <%- include('../partials/header-member', { activePage: 'browse-classes' }) %>
    <% } else { %>
      <%- include('../partials/header-public', { activePage: '' }) %>
    <% } %>

    <main class="container">
      <%- include('../partials/hero-video') %>

      <section class="section fade-in">
        <div class="section-head">
          <div><h2>Class Offers</h2><p>Book your spot in one of our elite training sessions.</p></div>
        </div>

        <% if (typeof classes !== 'undefined' && classes.length > 0) { %>
          <div class="class-grid">
            <% classes.forEach(function(cls) { %>
              <article class="class-card fade-in">
                <div class="toolbar">
                  <span class="pill success"><%= cls.category %></span>
                  <% if (cls.booked < cls.capacity) { %>
                    <span class="pill success"><%= cls.capacity - cls.booked %> spots left</span>
                  <% } else { %>
                    <span class="pill danger">Full</span>
                  <% } %>
                </div>

                <% if (cls.image) { %>
                  <img class="class-photo" src="<%= cls.image %>" alt="<%= cls.name %>" loading="lazy" style="width:100%;height:180px;object-fit:cover;border-radius:8px;margin:8px 0;" />
                <% } %>

                <h3><%= cls.name %></h3>
                <p><%= cls.description %></p>
                <% if (cls.trainer) { %><p style="color: var(--text-secondary); font-size: 0.9rem;">Trainer: <%= cls.trainer %></p><% } %>
                <% if (cls.time) { %><p style="color: var(--text-secondary); font-size: 0.9rem;">Time: <%= cls.time %></p><% } %>
                <p style="color: var(--primary-color); font-weight: 700; margin-top: 6px;">Level: <%= cls.level %></p>

                <div class="inline-actions" style="margin-top: 12px;">
                  <% if (!locals.sessionUser) { %>
                    <a href="/auth/login" class="btn btn-primary" style="flex: 1;">Login to Book</a>
                  <% } else if (sessionUser.role !== 'member') { %>
                    <button class="btn btn-secondary" disabled style="flex: 1; opacity: 0.6;">Members Only</button>
                  <% } else if (cls.booked >= cls.capacity) { %>
                    <button class="btn btn-secondary" disabled style="flex: 1; opacity: 0.6;">Class Full</button>
                  <% } else { %>
                    <form action="/member/book/<%= cls._id %>" method="POST" style="flex: 1;">
                      <button class="btn btn-primary" type="submit" style="width: 100%;">Book Class →</button>
                    </form>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-state" style="text-align: center; padding: 60px 20px; color: var(--text-muted);">
            <p style="font-size: 1.1rem; margin-bottom: 12px;">No classes available yet.</p>
            <p>Check back soon — new classes are added regularly.</p>
          </div>
        <% } %>
      </section>
    </main>
  </div>

  <%- include('../partials/login-modal') %>
</body>
</html>
