<%- include('../partials/head') %>
  <body data-page="member">
  <div class="app">
    <%- include('../partials/header-member', { activePage: 'my-orders' }) %>
    <main class="container">
      <%- include('../partials/hero-video') %>
      <section class="dashboard-layout">
        <div class="dashboard-banner fade-in">
          <div><h2>My Orders</h2><p>Your Power Temple Nutrition shop order history.</p></div>
          <a class="btn btn-primary" href="/shop">Shop More →</a>
        </div>

        <div class="stat-grid" style="margin-bottom: 32px;">
          <div class="stat fade-in"><strong><%= (orders || []).length %></strong><span>Total Orders</span></div>
          <div class="stat fade-in"><strong>LE <%= (orders || []).reduce(function(s, o){ return s + o.total; }, 0).toLocaleString() %></strong><span>Total Spent</span></div>
        </div>

        <div id="ordersSection">
        <div class="panel-head" style="margin-bottom: 16px;">
          <div><h3>Order History</h3></div>
        </div>

        <% if ((orders || []).length > 0) { %>
          <% orders.forEach(function(o) { %>
            <article class="row-card fade-in" id="order-<%= o._id %>" style="margin-bottom: 12px; flex-direction: column; align-items: stretch; gap: 8px;">
              <div class="row-main" style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                  <strong>Order #<%= o._id.toString().slice(-6).toUpperCase() %></strong>
                  <span class="row-meta"><%= new Date(o.createdAt).toLocaleString() %> · <%= o.items.length %> item(s) · <%= o.method %></span>
                </div>
                <div style="display: flex; gap: 8px; align-items: center;">
                  <span class="pill <%= o.status === 'paid' ? 'success' : (o.status === 'cancelled' ? 'danger' : 'warning') %>"><%= o.status %></span>
                  <strong>LE <%= Number(o.total).toLocaleString() %></strong>
                </div>
              </div>
              <ul style="margin: 0; padding-left: 20px; color: var(--text-secondary); font-size: 0.9rem;">
                <% o.items.forEach(function(it) { %>
                  <li><%= it.name %> × <%= it.qty %> — LE <%= Number(it.price * it.qty).toLocaleString() %></li>
                <% }) %>
              </ul>
            </article>
          <% }) %>
        <% } else { %>
          <p style="color: var(--text-muted);">No orders yet. <a href="/shop" style="color: var(--primary-color);">Visit the shop →</a></p>
        <% } %>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
