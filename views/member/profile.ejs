<%- include('../partials/head') %>
<body data-page="member">
  <div class="app">
    <%- include('../partials/header-member', { activePage: 'profile' }) %>
    <main class="container">
      <%- include('../partials/hero-video') %>
      <section class="dashboard-layout">
        <div class="dashboard-banner fade-in"><div><h2>My Profile</h2><p>Update your personal info and change your password to keep your account secure.</p></div></div>
        <div class="dashboard-grid" style="gap: 24px;">
          <div class="form-card fade-in">
            <h3 style="margin-bottom: 16px;">Personal Information</h3>
            <form id="profileForm">
              <label>Full Name<input id="profName" type="text" required /></label>
              <label>Email Address<input id="profEmail" type="email" required /></label>
              <label>Username<input id="profUsername" type="text" disabled style="opacity: 0.6;" /></label>
              <button class="btn btn-primary" type="submit" style="width: 100%;">Save Profile</button>
            </form>
          </div>
          <div class="form-card fade-in">
            <h3 style="margin-bottom: 16px;">Change Password</h3>
            <form id="passwordForm">
              <label>Current Password<input id="curPass" type="password" required /></label>
              <label>New Password<input id="newPass" type="password" placeholder="At least 8 chars, A-Z, a-z, 0-9" required /></label>
              <label>Confirm New Password<input id="confirmPass" type="password" required /></label>
              <button class="btn btn-primary" type="submit" style="width: 100%;">Update Password</button>
            </form>
          </div>
        </div>
        <div class="panel" style="margin-top: 24px;">
          <h3 style="margin-bottom: 12px;">Account Summary</h3>
          <div class="stat-grid" style="gap: 12px;">
            <div class="stat"><strong id="acctTier">—</strong><span>Membership Tier</span></div>
            <div class="stat"><strong id="acctSince">—</strong><span>Member Since</span></div>
            <div class="stat"><strong id="acctBookings">0</strong><span>Total Bookings</span></div>
            <div class="stat"><strong id="acctStatus">active</strong><span>Status</span></div>
          </div>
        </div>
        <div id="adminMessage" class="notice hidden" style="margin-top: 20px;"></div>
      </section>
    </main>
  </div>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      if (typeof PowerTempleAPI === 'undefined' || typeof auth === 'undefined') return;
      const user = auth.getCurrentUser();
      if (!user) return;
      document.getElementById('profName').value = user.name || '';
      document.getElementById('profEmail').value = user.email || '';
      document.getElementById('profUsername').value = user.username || '';
      document.getElementById('acctTier').textContent = user.membershipTier || '—';
      document.getElementById('acctSince').textContent = user.joiningDate || '—';
      document.getElementById('acctBookings').textContent = user.totalBookings || 0;
      document.getElementById('acctStatus').textContent = user.membershipStatus || 'active';
      document.getElementById('profileForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const name = document.getElementById('profName').value.trim();
        const email = document.getElementById('profEmail').value.trim();
        if (!auth.validateEmailFormat(email)) { showNotification('Invalid email', 'error'); return; }
        PowerTempleAPI.updateMemberInfo(user.id, { name, email });
        const updated = PowerTempleAPI.getUserById(user.id);
        const userCopy = { ...updated }; delete userCopy.password;
        auth.currentUser = userCopy; auth.saveToLocalStorage(userCopy);
        showNotification('Profile updated successfully', 'success');
      });
      document.getElementById('passwordForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const cur = document.getElementById('curPass').value;
        const np = document.getElementById('newPass').value;
        const cp = document.getElementById('confirmPass').value;
        if (np !== cp) { showNotification('Passwords do not match', 'error'); return; }
        if (!auth.validatePasswordStrength(np)) { showNotification('Password must be 8+ chars with uppercase, lowercase, and a number', 'error'); return; }
        const r = PowerTempleAPI.changeUserPassword(user.id, cur, np);
        if (r.success) { showNotification('Password updated', 'success'); e.target.reset(); } else { showNotification(r.message, 'error'); }
      });
    });
  </script>
</body>
</html>
