<%- include('../partials/head') %>
<body data-page="member">
  <div class="app">
    <%- include('../partials/header-member', { activePage: 'my-bookings' }) %>
    <main class="container">
      <%- include('../partials/hero-video') %>
      <section class="dashboard-layout">
        <div class="dashboard-banner fade-in">
          <div><h2>My Class Bookings</h2><p>Your upcoming and past training sessions.</p></div>
          <a class="btn btn-primary" href="/member/browse-classes">Book More Classes</a>
        </div>

        <div class="stat-grid" style="margin-bottom: 32px;">
          <%
            var upcoming = (bookings || []).filter(function(b){ return b.status === 'confirmed'; });
            var past     = (bookings || []).filter(function(b){ return b.status !== 'confirmed'; });
          %>
          <div class="stat fade-in"><strong><%= upcoming.length %></strong><span>Upcoming</span></div>
          <div class="stat fade-in"><strong><%= past.length %></strong><span>Completed</span></div>
          <div class="stat fade-in"><strong><%= (bookings || []).length %></strong><span>Total</span></div>
        </div>

        <div id="bookingsSection">
        <div class="panel-head" style="margin-bottom: 16px;">
          <div><h3>Upcoming Sessions</h3></div>
        </div>

        <% if (upcoming.length > 0) { %>
          <% upcoming.forEach(function(b) { %>
            <article class="row-card fade-in" id="booking-<%= b._id %>" style="margin-bottom: 12px;">
              <div class="row-main">
                <strong><%= b.className %></strong>
                <span class="row-meta"><%= b.time || '' %> · <%= b.trainer || '' %> · <%= b.room || '' %></span>
              </div>
              <div style="display: flex; gap: 8px; align-items: center;">
                <span class="pill success">Confirmed</span>
                <button class="btn btn-ghost cancel-booking-btn" type="button" data-booking-id="<%= b._id %>" style="padding: 6px 12px; font-size: 0.85rem; color: var(--danger-color);">Cancel</button>
              </div>
            </article>
          <% }) %>
        <% } else { %>
          <p style="color: var(--text-muted);">No upcoming bookings. <a href="/member/browse-classes" style="color: var(--primary-color);">Browse classes →</a></p>
        <% } %>

        <div class="panel-head" style="margin: 32px 0 16px;">
          <div><h3>Past Sessions</h3></div>
        </div>

        <% if (past.length > 0) { %>
          <% past.forEach(function(b) { %>
            <article class="row-card fade-in" id="booking-<%= b._id %>" style="margin-bottom: 12px;">
              <div class="row-main">
                <strong><%= b.className %></strong>
                <span class="row-meta"><%= b.trainer || '' %></span>
              </div>
              <span class="pill warning"><%= b.status %></span>
            </article>
          <% }) %>
        <% } else { %>
          <p style="color: var(--text-muted);">No past sessions yet.</p>
        <% } %>
        </div>

        <div id="adminMessage" class="notice hidden" style="margin-top: 20px;"></div>
      </section>
    </main>
  </div>
  <script>
    document.querySelectorAll('.cancel-booking-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (!confirm('Cancel this booking?')) return;

        var bookingId = btn.dataset.bookingId;
        var card = btn.closest('.row-card');
        btn.disabled = true;
        btn.textContent = 'Cancelling...';

        fetch('/member/cancel/' + bookingId, {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
        })
          .then(function (res) { return res.json(); })
          .then(function (data) {
            if (data.status === 'success') {
              card.style.transition = 'opacity 0.25s ease';
              card.style.opacity = '0';
              setTimeout(function () { card.remove(); }, 250);
            } else {
              alert(data.message || 'Failed to cancel booking');
              btn.disabled = false;
              btn.textContent = 'Cancel';
            }
          })
          .catch(function () {
            alert('Network error. Please try again.');
            btn.disabled = false;
            btn.textContent = 'Cancel';
          });
      });
    });
  </script>
</body>
</html>
